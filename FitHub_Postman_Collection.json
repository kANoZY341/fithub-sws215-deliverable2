    {
      "name": "AUTH",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const email = `postman.user.${Date.now()}@fithub.local`;",
                  "pm.collectionVariables.set('userEmail', email);",
                  "pm.collectionVariables.set('userPassword', 'Member@123');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('User registered', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('userToken', data.token);",
                  "  pm.environment.set('userId', data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Test User\",\n  \"email\": \"{{userEmail}}\",\n  \"phone\": \"+971501234567\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Creates a fresh normal user and saves userToken and userId automatically."
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('User login succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
