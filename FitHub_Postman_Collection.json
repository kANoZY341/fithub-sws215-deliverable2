                "type": "text/javascript",
                "exec": [
                  "pm.test('My memberships returned', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const memberships = pm.response.json();",
                  "if (Array.isArray(memberships) && memberships.length) {",
                  "  pm.environment.set('membershipId', memberships[0]._id);",
                  "}"
                ]
              }
