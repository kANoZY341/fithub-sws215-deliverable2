          ]
        },
        {
          "name": "Subscribe to Membership Plan",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planId\": \"{{planId}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/memberships/subscribe",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "memberships",
                "subscribe"
              ]
            },
            "description": "Creates a membership for a user with no active plan. If the user already has an active plan, the backend correctly returns 409."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Subscription created or blocked when user already has active plan', function () {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('membershipId', data._id);",
                  "} else if (pm.response.code === 409) {",
                  "  pm.test('Duplicate active membership message is correct', function () {",
                  "    pm.expect(pm.response.json().message).to.eql('User already has an active membership plan.');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Duplicate Membership Test - should return 409 if user already has active plan",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planId\": \"{{planId}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/memberships/subscribe",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "memberships",
                "subscribe"
              ]
            },
            "description": "Run this after Subscribe to Membership Plan for the same user. Expected: 409 Conflict."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Duplicate active membership is blocked', function () {",
                  "  pm.response.to.have.status(409);",
                  "});",
                  "pm.test('Conflict message is correct', function () {",
                  "  pm.expect(pm.response.json().message).to.eql('User already has an active membership plan.');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
